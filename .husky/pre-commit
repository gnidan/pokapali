#!/usr/bin/env sh

# Block direct commits to main — use a feature branch
# and merge-branch.sh instead.
# Exception: bin/release.sh sets POKAPALI_RELEASE=1
# so release commits still get lint-staged formatting.
branch=$(git branch --show-current)
case "$branch" in
  main|release/*)
    if [ "${POKAPALI_RELEASE:-}" != "1" ]; then
      echo "ERROR: Direct commits to $branch" \
        "are blocked."
      echo "Create a feature branch and use" \
        "merge-branch.sh."
      exit 1
    fi
    ;;
esac

npx lint-staged
