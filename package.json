{
  "name": "pokapali",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @pokapali/example",
    "postinstall": "patch-package",
    "build": "tsc --build",
    "test": "POKAPALI_LOG_LEVEL=silent vitest run --workspace vitest.workspace.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev:node": "npx pokapali --storage-path /tmp/pokapali-node --relay --pin pokapali-example --port 3001"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.0.0"
  }
}
