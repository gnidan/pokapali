{
  "name": "@pokapali/test-utils",
  "version": "0.1.0-alpha.16",
  "description": "Shared test utilities for pokapali packages",
  "keywords": [
    "pokapali",
    "testing",
    "utilities",
    "libp2p"
  ],
  "homepage": "https://github.com/gnidan/pokapali/tree/main/packages/test-utils",
  "repository": {
    "type": "git",
    "url": "https://github.com/gnidan/pokapali.git",
    "directory": "packages/test-utils"
  },
  "author": "g. nicholas d'andrea <nick@gnidan.org>",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src/**/*.js",
    "dist/src/**/*.d.ts",
    "dist/src/**/*.js.map",
    "!dist/src/**/*.test.*"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@chainsafe/libp2p-gossipsub": "^14.1.2",
    "@chainsafe/libp2p-noise": "^16.1.0",
    "@chainsafe/libp2p-yamux": "^7.0.1",
    "@libp2p/circuit-relay-v2": "^3.2.0",
    "@libp2p/identify": "^3.0.0",
    "@libp2p/websockets": "^9.1.0",
    "libp2p": "^2.9.0"
  },
  "peerDependencies": {
    "yjs": "^13.6.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "yjs": "^13.6.0"
  },
  "engines": {
    "node": ">=22"
  }
}
