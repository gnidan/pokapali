{
  "name": "@pokapali/subdocs",
  "version": "0.1.2",
  "description": "Multi-channel Yjs subdocument management for pokapali",
  "keywords": [
    "pokapali",
    "yjs",
    "subdocs",
    "channels",
    "crdt"
  ],
  "homepage": "https://github.com/gnidan/pokapali/tree/main/packages/subdocs",
  "repository": {
    "type": "git",
    "url": "https://github.com/gnidan/pokapali.git",
    "directory": "packages/subdocs"
  },
  "author": "g. nicholas d'andrea <nick@gnidan.org>",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/src/**/*.js",
    "dist/src/**/*.d.ts",
    "dist/src/**/*.js.map",
    "!dist/src/**/*.test.*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "license": "MIT",
  "peerDependencies": {
    "yjs": "^13.6.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "yjs": "^13.6.0"
  },
  "engines": {
    "node": ">=22"
  }
}
