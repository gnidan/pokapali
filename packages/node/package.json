{
  "name": "@pokapali/node",
  "version": "0.1.0-alpha.3",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/src/**/*.js",
    "dist/src/**/*.d.ts",
    "dist/src/**/*.js.map",
    "dist/bin/**/*.js",
    "!dist/src/**/*.test.*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "license": "MIT",
  "bin": {
    "pokapali": "dist/bin/node.js"
  },
  "scripts": {
    "build": "tsc --build",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@chainsafe/libp2p-gossipsub": "^14.1.2",
    "@helia/ipns": "^8.2.4",
    "@ipshipyard/libp2p-auto-tls": "^1.0.0",
    "@libp2p/crypto": "^5.0.0",
    "@libp2p/kad-dht": "^15.1.11",
    "@libp2p/pubsub-peer-discovery": "^12.0.0",
    "@pokapali/core": "0.1.0-alpha.3",
    "@pokapali/crypto": "0.1.0-alpha.3",
    "@pokapali/log": "0.1.0-alpha.3",
    "@pokapali/snapshot": "0.1.0-alpha.3",
    "blockstore-fs": "3.0.2",
    "datastore-level": "^12.0.2",
    "helia": "^5.5.1",
    "ipns": "^10.0.0",
    "multiformats": "^13.3.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
