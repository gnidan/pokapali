{
  "name": "@pokapali/comments",
  "version": "0.1.0-alpha.15",
  "description": "Anchored, attributed, threaded comments for Yjs documents",
  "keywords": [
    "pokapali",
    "comments",
    "yjs",
    "crdt",
    "collaboration",
    "annotations"
  ],
  "homepage": "https://github.com/gnidan/pokapali/tree/main/packages/comments",
  "repository": {
    "type": "git",
    "url": "https://github.com/gnidan/pokapali.git",
    "directory": "packages/comments"
  },
  "author": "g. nicholas d'andrea <nick@gnidan.org>",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src/**/*.js",
    "dist/src/**/*.d.ts",
    "dist/src/**/*.js.map",
    "!dist/src/**/*.test.*"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@pokapali/log": "0.1.0-alpha.15"
  },
  "peerDependencies": {
    "yjs": "^13.6.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "yjs": "^13.6.0"
  },
  "engines": {
    "node": ">=22"
  }
}
