{
  "name": "@pokapali/react",
  "version": "0.1.2",
  "description": "React hooks for pokapali documents",
  "keywords": [
    "pokapali",
    "react",
    "hooks",
    "crdt",
    "collaboration"
  ],
  "homepage": "https://github.com/gnidan/pokapali/tree/main/packages/react",
  "repository": {
    "type": "git",
    "url": "https://github.com/gnidan/pokapali.git",
    "directory": "packages/react"
  },
  "author": "g. nicholas d'andrea <nick@gnidan.org>",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./comments.css": "./src/comments.css"
  },
  "files": [
    "dist/src/**/*.js",
    "dist/src/**/*.d.ts",
    "dist/src/**/*.js.map",
    "!dist/src/**/*.test.*",
    "src/comments.css"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@pokapali/comments": "^0.1.1",
    "@pokapali/core": "^0.1.1",
    "@tiptap/pm": "^2.0.0",
    "react": ">=18",
    "yjs": "^13.6.0"
  },
  "peerDependenciesMeta": {
    "@pokapali/comments": {
      "optional": true
    },
    "@tiptap/pm": {
      "optional": true
    },
    "yjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@pokapali/comments": "^0.1.1",
    "@pokapali/core": "^0.1.1",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
