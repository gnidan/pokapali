{
  "name": "@pokapali/react",
  "version": "0.1.0-alpha.13",
  "description": "React hooks for pokapali documents",
  "keywords": [
    "pokapali",
    "react",
    "hooks",
    "crdt",
    "collaboration"
  ],
  "homepage": "https://github.com/gnidan/pokapali/tree/main/packages/react",
  "repository": {
    "type": "git",
    "url": "https://github.com/gnidan/pokapali.git",
    "directory": "packages/react"
  },
  "author": "g. nicholas d'andrea <nick@gnidan.org>",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
