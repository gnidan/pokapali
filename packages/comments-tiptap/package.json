    "yjs": "^13.6.0"
  },
  "devDependencies": {
    "@pokapali/comments": "0.1.0-alpha.16",
    "@tiptap/core": "^2.12.0",
    "@tiptap/pm": "^2.12.0",
    "typescript": "^5.7.0",
