    "pokapali",
    "comments",
    "tiptap",
    "prosemirror",
    "yjs",
    "collaboration"
  ],
  "homepage": "https://github.com/gnidan/pokapali/tree/main/packages/comments-tiptap",
  "repository": {
    "type": "git",
    "url": "https://github.com/gnidan/pokapali.git",
    "directory": "packages/comments-tiptap"
  },
  "author": "g. nicholas d'andrea <nick@gnidan.org>",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
