{
  "name": "@pokapali/protocol",
  "version": "0.0.0",
  "description": "Protocol-layer primitives for pokapali (BlockResolver impl, session coordination)",
  "keywords": [
    "pokapali",
    "p2p",
    "sync",
    "protocol"
  ],
  "homepage": "https://github.com/gnidan/pokapali/tree/main/packages/protocol",
  "repository": {
    "type": "git",
    "url": "https://github.com/gnidan/pokapali.git",
    "directory": "packages/protocol"
  },
  "author": "g. nicholas d'andrea <nick@gnidan.org>",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/src/**/*.js",
    "dist/src/**/*.d.ts",
    "dist/src/**/*.js.map",
    "!dist/src/**/*.test.*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@pokapali/core": "^0.1.6",
    "@pokapali/log": "^0.1.1",
    "multiformats": "^13.3.0"
  },
  "devDependencies": {
    "fast-check": "^4.7.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
