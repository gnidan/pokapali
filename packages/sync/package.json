{
  "name": "@pokapali/sync",
  "version": "0.1.0-alpha.5",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/src/**/*.js",
    "dist/src/**/*.d.ts",
    "dist/src/**/*.js.map",
    "!dist/src/**/*.test.*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "license": "MIT",
  "dependencies": {
    "@pokapali/log": "0.1.0-alpha.5",
    "@pokapali/subdocs": "0.1.0-alpha.5",
    "lib0": "^0.2.117",
    "y-webrtc": "^10.3.0"
  },
  "peerDependencies": {
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.0"
  },
  "engines": {
    "node": ">=22"
  }
}
