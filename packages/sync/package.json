{
  "name": "@pokapali/sync",
  "version": "0.1.2",
  "description": "WebRTC sync provider for pokapali documents",
  "keywords": [
    "pokapali",
    "sync",
    "webrtc",
    "yjs",
    "crdt",
    "p2p"
  ],
  "homepage": "https://github.com/gnidan/pokapali/tree/main/packages/sync",
  "repository": {
    "type": "git",
    "url": "https://github.com/gnidan/pokapali.git",
    "directory": "packages/sync"
  },
  "author": "g. nicholas d'andrea <nick@gnidan.org>",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/src/**/*.js",
    "dist/src/**/*.d.ts",
    "dist/src/**/*.js.map",
    "!dist/src/**/*.test.*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "license": "MIT",
  "dependencies": {
    "@noble/hashes": "^1.3.1",
    "@pokapali/blocks": "^0.1.2",
    "@pokapali/codec": "^0.0.0",
    "@pokapali/document": "^0.0.0",
    "@pokapali/finger-tree": "^0.0.0",
    "@pokapali/log": "^0.1.1",
    "lib0": "^0.2.117",
    "multiformats": "^13.3.0"
  },
  "peerDependencies": {
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.0"
  },
  "devDependencies": {
    "@pokapali/crypto": "^0.1.1",
    "@pokapali/store": "^0.0.0",
    "fake-indexeddb": "^6.0.0",
    "fast-check": "^4.6.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.0"
  },
  "engines": {
    "node": ">=22"
  }
}
