{
  "name": "@pokapali/crypto",
  "version": "0.1.0-alpha.3",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/src/**/*.js",
    "dist/src/**/*.d.ts",
    "dist/src/**/*.js.map",
    "!dist/src/**/*.test.*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "license": "MIT",
  "dependencies": {
    "@noble/ed25519": "^2.2.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
