{
  "name": "@pokapali/snapshot",
  "version": "0.1.0-alpha.13",
  "description": "Encrypted snapshot encoding and versioning for pokapali documents",
  "keywords": [
    "pokapali",
    "snapshot",
    "ipfs",
    "dag-cbor",
    "versioning"
  ],
  "homepage": "https://github.com/gnidan/pokapali/tree/main/packages/snapshot",
  "repository": {
    "type": "git",
    "url": "https://github.com/gnidan/pokapali.git",
    "directory": "packages/snapshot"
  },
  "author": "g. nicholas d'andrea <nick@gnidan.org>",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/src/**/*.js",
    "dist/src/**/*.d.ts",
    "dist/src/**/*.js.map",
    "!dist/src/**/*.test.*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "license": "MIT",
  "dependencies": {
    "@pokapali/crypto": "0.1.0-alpha.13",
    "@ipld/dag-cbor": "^9.2.0",
    "multiformats": "^13.3.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
