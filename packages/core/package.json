{
  "name": "@pokapali/core",
  "version": "0.1.6",
  "description": "P2P collaborative document sync using Yjs, WebRTC, and IPFS",
  "keywords": [
    "pokapali",
    "crdt",
    "yjs",
    "p2p",
    "collaboration",
    "webrtc",
    "ipfs",
    "sync"
  ],
  "homepage": "https://github.com/gnidan/pokapali/tree/main/packages/core",
  "repository": {
    "type": "git",
    "url": "https://github.com/gnidan/pokapali.git",
    "directory": "packages/core"
  },
  "author": "g. nicholas d'andrea <nick@gnidan.org>",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/src/**/*.js",
    "dist/src/**/*.d.ts",
    "dist/src/**/*.js.map",
    "!dist/src/**/*.test.*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./announce": {
      "types": "./dist/src/announce.d.ts",
      "default": "./dist/src/announce.js"
    },
    "./block-upload": {
      "types": "./dist/src/block-upload.d.ts",
      "default": "./dist/src/block-upload.js"
    },
    "./snapshot-codec": {
      "types": "./dist/src/snapshot-codec.d.ts",
      "default": "./dist/src/snapshot-codec.js"
    },
    "./ipns-helpers": {
      "types": "./dist/src/ipns-helpers.d.ts",
      "default": "./dist/src/ipns-helpers.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@chainsafe/libp2p-gossipsub": "^14.1.2",
    "@helia/ipns": "^8.2.4",
    "@ipld/dag-cbor": "^9.2.0",
    "@libp2p/crypto": "^5.0.0",
    "@libp2p/pubsub-peer-discovery": "^12.0.0",
    "@noble/hashes": "^1.3.1",
    "@pokapali/capability": "^0.1.2",
    "@pokapali/codec": "^0.0.0",
    "@pokapali/document": "^0.0.0",
    "@pokapali/crypto": "^0.1.1",
    "@pokapali/finger-tree": "^0.0.0",
    "@pokapali/log": "^0.1.1",
    "@pokapali/blocks": "^0.1.2",
    "@pokapali/store": "^0.0.0",
    "@pokapali/sync": "^0.1.2",
    "blockstore-idb": "3.0.1",
    "helia": "^5.5.1",
    "multiformats": "^13.3.0",
    "y-indexeddb": "^9.0.12"
  },
  "peerDependencies": {
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.0"
  },
  "devDependencies": {
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^4.6.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.0"
  },
  "engines": {
    "node": ">=22"
  }
}
