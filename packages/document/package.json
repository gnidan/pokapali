{
  "name": "@pokapali/document",
  "version": "0.0.0",
  "description": "Document history model for pokapali",
  "keywords": [
    "pokapali",
    "document",
    "history",
    "epoch",
    "finger-tree"
  ],
  "homepage": "https://github.com/gnidan/pokapali/tree/main/packages/document",
  "repository": {
    "type": "git",
    "url": "https://github.com/gnidan/pokapali.git",
    "directory": "packages/document"
  },
  "author": "g. nicholas d'andrea <nick@gnidan.org>",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/src/**/*.js",
    "dist/src/**/*.d.ts",
    "dist/src/**/*.js.map",
    "!dist/src/**/*.test.*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "imports": {
    "#history": "./src/history/index.ts",
    "#state": "./src/state/index.ts",
    "#fingerprint": "./src/fingerprint/index.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "license": "MIT",
  "dependencies": {
    "@noble/hashes": "^1.3.1",
    "@pokapali/codec": "^0.0.0",
    "@pokapali/crypto": "^0.1.1",
    "@pokapali/finger-tree": "^0.0.0",
    "multiformats": "^13.3.0"
  },
  "devDependencies": {
    "fast-check": "^4.6.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
