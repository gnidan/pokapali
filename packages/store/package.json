{
  "name": "@pokapali/store",
  "version": "0.0.0",
  "description": "IndexedDB epoch persistence for pokapali documents",
  "keywords": [
    "pokapali",
    "store",
    "epoch",
    "indexeddb",
    "persistence"
  ],
  "homepage": "https://github.com/gnidan/pokapali/tree/main/packages/store",
  "repository": {
    "type": "git",
    "url": "https://github.com/gnidan/pokapali.git",
    "directory": "packages/store"
  },
  "author": "g. nicholas d'andrea <nick@gnidan.org>",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/src/**/*.js",
    "dist/src/**/*.d.ts",
    "dist/src/**/*.js.map",
    "!dist/src/**/*.test.*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "license": "MIT",
  "dependencies": {
    "@pokapali/document": "^0.0.0",
    "multiformats": "^13.3.0"
  },
  "devDependencies": {
    "@noble/hashes": "^1.3.1",
    "fake-indexeddb": "^6.0.0",
    "fast-check": "^4.6.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
